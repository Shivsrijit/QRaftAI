# VedaAI Assessment Creator - Environment Configuration

# 1. Server Configuration
PORT=5001
WS_PORT=5002

# 2. MongoDB Database Configuration
# If left blank, the system automatically runs an in-memory MongoDB database server.
# For production/persistent data, provide a local MongoDB URI or a MongoDB Atlas URI.
# Example: MONGODB_URI=mongodb://localhost:27017/veda-ai
MONGODB_URI=

# 3. Redis & BullMQ Configuration
# If left blank, the system will gracefully process jobs in-memory.
# For production queue management and background job workers, run a local Redis or cloud Redis (e.g. Upstash/RedisLabs) and provide the URI.
# Example: REDIS_URL=redis://localhost:6379
REDIS_URL=

# 4. Google Gemini AI API Configuration
# Get a FREE API Key from Google AI Studio (https://aistudio.google.com/)
# If left blank, the application will run in MOCK mode using rich pre-authored question sets for common academic subjects.
# Example: GEMINI_API_KEY=AIzaSyA1...
GEMINI_API_KEY=
